        {"fx": "text.countUp", "target": "num", "at": 400, "params": {"to": {"$content": "value", "fallback": 72.5}, "decimals": {"$content": "decimals", "fallback": 1}, "suffix": {"$content": "suffix", "fallback": "%"}, "duration": 1400}},
