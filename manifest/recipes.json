{
  "schemaVersion": 1,
  "roleReference": "参数值 {$role:'accent'} 由使用方设计系统注入；demo 编译时从 exampleTheme 夹具机械代入。{$roles:[...]} 生成角色色数组；禁止裸 hex。",
  "recipes": [
    {
      "id": "cover.particleScramble",
      "exampleTheme": "techNoir",
      "roles": ["bg", "ink", "accent", "muted"],
      "contentSlots": ["title", "subtitle", "badge"],
      "type": "cover",
      "duration": 5000,
      "template": "cover-text",
      "effects": [
        {"fx": "canvas.particles", "target": "bg", "at": 0, "params": {"link": true, "count": 60, "color": {"$role": "accent"}, "linkColor": {"$role": "muted", "alpha": 0.32}, "bg": {"$role": "bg"}, "drift": 30, "seed": 7, "period": 5000}},
        {"fx": "text.scrambleIn", "target": "title", "at": 300, "params": {"seed": 7, "duration": 1800}},
        {"fx": "text.charsReveal", "target": "sub", "at": 1100, "params": {"from": "first"}},
        {"fx": "svg.draw", "target": "ruleLine", "at": 1600, "params": {}},
        {"fx": "text.highlightSweep", "target": "badge", "at": 2000, "params": {"color": {"$role": "accent"}}}
      ]
    },
    {
      "id": "coverHero.gridAssemble",
