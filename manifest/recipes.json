{
  "schemaVersion": 2,
  "roleReference": "参数值 {$role:'accent'} 由使用方设计系统注入；demo 编译时从 demos/fixtures/ 的展示夹具机械代入。{$roles:[...]} 生成角色色数组；禁止裸 hex。exampleTheme 一律为 neutral：recipe 是风格无关的编排合同，demo 观感来自展示夹具，不构成风格推荐。",
  "recipes": [
    {
      "id": "saas.launchHero",
      "exampleTheme": "neutral",
      "roles": ["bg", "ink", "accent", "muted"],
      "contentSlots": ["title", "subtitle", "badge", "items"],
      "type": "hero",
      "duration": 7000,
      "template": "saas-hero",
      "effects": [
        {"fx": "shader.meshGradient", "target": "shader", "at": 0, "params": {"speed": 0.22, "colors": {"$roles": ["bg", "bg", "accent", "muted"]}, "distortion": 0.16, "swirl": 0.025}},
        {"fx": "stagger.cardsSpring", "target": "foreground", "at": 120, "params": {"from": "first", "step": 120, "y": 28, "scale": 0.98, "damping": 18}},
        {"fx": "text.wordsAppear", "target": "title", "at": 300, "params": {"duration": 780, "y": 24}},
        {"fx": "text.highlightSweep", "target": "titleFocus", "at": 2100, "params": {"color": {"$role": "accent", "alpha": 0.28}, "height": "18%", "vpos": "96%", "duration": 620}},
        {"fx": "ui.notifyDrop", "target": "deployNotify", "at": 2850, "params": {"icon": "✓", "text": "Deploy complete · pulse-web is live", "hold": 1400, "duration": 650}}
      ]
    },
